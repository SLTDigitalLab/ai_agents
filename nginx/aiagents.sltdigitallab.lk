server {
    listen 80;
    server_name aiagents.sltdigitallab.lk;

    # Redirect all HTTP to HTTPS
    return 301 https://$host$request_uri;
}

server {
    listen 443 ssl;
    server_name aiagents.sltdigitallab.lk;

    # SSL certificates (managed by Certbot or manually placed)
    ssl_certificate     /etc/letsencrypt/live/aiagents.sltdigitallab.lk/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/aiagents.sltdigitallab.lk/privkey.pem;

    ssl_protocols TLSv1.2 TLSv1.3;
    ssl_ciphers HIGH:!aNULL:!MD5;

    # Frontend
    location / {
        proxy_pass http://127.0.0.1:3100;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
    }

    # Backend API
    location /api/ {
        proxy_pass http://127.0.0.1:8100;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";

        # 10-minute timeouts for long-running ingestion endpoint
        proxy_read_timeout    600s;
        proxy_connect_timeout 600s;
        proxy_send_timeout    600s;

        # Allow large file uploads for document ingestion
        client_max_body_size 100M;
    }
}
